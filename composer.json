{
    "name": "philiprehberger/php-webhook-signature",
    "description": "Minimal, framework-agnostic HMAC-SHA256 webhook signature generation and verification with replay attack prevention.",
    "type": "library",
    "keywords": ["webhook", "signature", "hmac", "sha256", "security", "stripe"],
    "homepage": "https://github.com/philiprehberger/webhook-signature",
    "license": "MIT",
    "authors": [
        {
            "name": "Philip Rehberger",
            "email": "me@philiprehberger.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.12|^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\WebhookSignature\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\WebhookSignature\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
